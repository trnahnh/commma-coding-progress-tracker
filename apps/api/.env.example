DATABASE_URL=postgresql://user:password@host:5432/commma
REDIS_URL=redis://localhost:6379
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/v1/auth/github/callback
JWT_SECRET=
REFRESH_TOKEN_SECRET=
WEB_ORIGIN=http://localhost:5173
PORT=3000

# Postgres connection pool size for this process (postgres-js `max`). Keep it
# modest on a single t4g.micro against Neon — 10 is the default. Raise only with
# headroom on both the instance and the Neon compute/connection limits.
DB_POOL_MAX=10

# Stripe billing (Pro/Team subscriptions). ALL optional — leave blank to run
# without billing; /v1/billing/* then returns 503 SERVICE_UNAVAILABLE and plans
# stay 'free'. STRIPE_WEBHOOK_SECRET is the signing secret for the endpoint you
# register at POST /v1/billing/webhook (use `stripe listen` for local testing).
# The four price IDs map a plan+interval to a Stripe recurring price; a price ID
# is also how the webhook resolves a subscription back to a plan.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_YEARLY=

# Run the background jobs (aggregation, streak reset, token cleanup, push,
# recap) on this process. Each tick takes a Redis leader lock (one run per
# interval across the fleet), so it is safe to leave this true on every
# instance — but the recommended posture is still to enable it on a single
# worker. Set false to opt a process out entirely. SIGTERM/SIGINT drain
# in-flight requests and let a running aggregation transaction finish before
# the process exits, so rolling deploys do not corrupt a session.
RUN_AGGREGATION=true

# Number of trusted proxies in front of the API, used to find the real client
# IP for IP-based rate limiting. The client can forge X-Forwarded-For, so we
# count this many hops in from the trusted (right) end.
#   0 = no proxy / direct (default, local dev)
#   1 = one AWS load balancer (ALB) in front
#   2 = CloudFront -> ALB in front
# IMPORTANT: also lock the instance's security group so ONLY the load balancer
# can reach it. If clients can hit the instance directly, they can forge
# X-Forwarded-For and this setting cannot protect against it.
# NOTE: the hop count assumes the ALB/CloudFront DEFAULT of appending the client
# IP to X-Forwarded-For. If you change the ALB's routing.http.xff_header_processing
# attribute (append is the default) to preserve/remove, re-check this value.
TRUST_PROXY_HOPS=0

# Push notifications (streak reminders). ALL optional — leave blank to disable;
# /v1/push/* then returns 503 SERVICE_UNAVAILABLE. Generate VAPID keys once with:
#   npx web-push generate-vapid-keys
# VAPID_SUBJECT must be a mailto: or https: URI identifying the app operator.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Weekly recap email (Pro/Team tier). The job runs Mondays at/after
# RECAP_SEND_HOUR_UTC (gated by RUN_AGGREGATION) over the prior Mon-Sun week.
# RESEND_API_KEY + RECAP_FROM_EMAIL are required to send — leave blank and the
# job no-ops. RECAP_FROM_EMAIL must use a Resend-verified domain, e.g.
# "Commma <recap@commma.dev>". OPENAI_API_KEY is optional: when set, gpt-4.1-nano
# writes the headline/note for every Pro/Team recipient (numbers stay
# deterministic; it falls back to a template on any error).
RESEND_API_KEY=
RECAP_FROM_EMAIL=
OPENAI_API_KEY=
RECAP_SEND_HOUR_UTC=13

# Deploy host requirement: the API uses sharp (heatmap-card PNG), whose prebuilt
# binary needs glibc >= 2.28. Amazon Linux 2023 or Ubuntu 20.04+ work; Amazon
# Linux 2 (glibc 2.26) does NOT — sharp fails to load and the server won't boot.
# (Alpine/musl is also supported.) The host must also have a monospace font
# (e.g. DejaVu/Liberation) installed for the card's text to render.
