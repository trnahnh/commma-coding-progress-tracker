{
  "name": "commma",
  "displayName": "commma",
  "description": "Track your coding activity with commma",
  "version": "1.0.0",
  "publisher": "commma",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Visualization"],
  "keywords": ["coding", "activity", "tracker", "heatmap", "productivity", "keyboard"],
  "galleryBanner": {
    "color": "#0c0b08",
    "theme": "dark"
  },
  "homepage": "https://commma.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/trnahnh/commma-coding-progress-tracker.git",
    "directory": "apps/extension"
  },
  "bugs": {
    "url": "https://github.com/trnahnh/commma-coding-progress-tracker/issues"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commma.signIn",
        "title": "commma: Sign in"
      },
      {
        "command": "commma.signOut",
        "title": "commma: Sign out"
      },
      {
        "command": "commma.toggleTracking",
        "title": "commma: Pause / Resume tracking"
      }
    ],
    "configuration": {
      "title": "commma",
      "properties": {
        "commma.apiBaseUrl": {
          "type": "string",
          "default": "https://api.commma.dev",
          "description": "Base URL of the commma API."
        },
        "commma.privacy": {
          "type": "string",
          "enum": ["full", "summary", "off"],
          "enumDescriptions": [
            "Send all fields, including file paths and key-label frequency.",
            "Send duration, keystrokes, and lines only — no file paths, no key frequency.",
            "Track nothing and send nothing."
          ],
          "default": "full",
          "description": "Controls how much activity data the extension sends."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "esbuild src/extension.ts --bundle --platform=node --target=node20 --external:vscode --format=cjs --minify --outfile=dist/extension.js",
    "build": "esbuild src/extension.ts --bundle --platform=node --target=node20 --external:vscode --format=cjs --sourcemap --outfile=dist/extension.js",
    "watch": "esbuild src/extension.ts --bundle --platform=node --target=node20 --external:vscode --format=cjs --sourcemap --watch --outfile=dist/extension.js",
    "dev": "pnpm run watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "publish:openvsx": "ovsx publish --no-dependencies",
    "publish:all": "pnpm run publish && pnpm run publish:openvsx"
  },
  "dependencies": {
    "@commma/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.24.2",
    "ovsx": "^1.0.1",
    "typescript": "^5.8.3"
  }
}
